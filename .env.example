PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/erpdigital?retryWrites=true&w=majority

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-key
JWT_EXPIRES_IN=7d

# Gmail SMTP (OTP emails)
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Optional: seed default admin on first run
ADMIN_EMAIL=admin@erpdigital.com
ADMIN_PASSWORD=Admin@123456

# Frontend URL (CORS)
CLIENT_URL=http://localhost:5173
